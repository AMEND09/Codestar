        {
          "id": "u2-l2",
          "title": "Sliding Window",
          "focus": "Move without restarting to keep O(n) time",
          "xp": 35,
          "mascot": "parens",
          "questions": [
            {
              "id": "u2-l2-q1",
              "type": "multiple_choice",
              "prompt": "Compare brute force and sliding window complexity.",
              "code": [
                "# Version A",
                "def max_sum_brute(arr, k):",
                "    max_sum = 0",
                "    for i in range(len(arr) - k + 1):",
                "        window_sum = sum(arr[i:i+k])",
                "        max_sum = max(max_sum, window_sum)",
                "    return max_sum",
                "",
                "# Version B",
                "def max_sum_sliding(arr, k):",
                "    window_sum = sum(arr[:k])",
                "    max_sum = window_sum",
                "    for i in range(k, len(arr)):",
                "        window_sum += arr[i] - arr[i - k]",
                "        max_sum = max(max_sum, window_sum)",
                "    return max_sum"
              ],
              "choices": [
                "O(n·k) for brute force, O(n) for sliding",
                "O(n) for both",
                "O(n^2) and O(n log n)",
                "O(k) and O(n)"
              ],
              "answerIndex": 0,
              "explanation": "Resumming every window is n·k; reusing the sum makes it linear."
            }
          ]
        },
